# Rust 拡張モジュール pylopdf_core の型スタブ
class PdfError(ValueError): ...
class PasswordError(PdfError): ...

class Pixmap:
    @property
    def width(self) -> int: ...
    @property
    def height(self) -> int: ...
    @property
    def n(self) -> int: ...
    @property
    def stride(self) -> int: ...
    @property
    def samples(self) -> bytes: ...
    def tobytes(self) -> bytes: ...

class _Document:
    def __init__(self) -> None: ...
    @staticmethod
    def load(path: str, password: str | None = None, max_decompressed_size: int | None = None) -> _Document: ...
    @staticmethod
    def load_bytes(data: bytes, password: str | None = None, max_decompressed_size: int | None = None) -> _Document: ...
    @staticmethod
    def load_metadata(path: str, password: str | None = None) -> tuple[dict[str, str], int, str, bool]: ...
    @staticmethod
    def load_metadata_bytes(data: bytes, password: str | None = None) -> tuple[dict[str, str], int, str, bool]: ...
    def is_encrypted(self) -> bool: ...
    def was_encrypted(self) -> bool: ...
    def set_fallback_font(self, kind: str, data: bytes, index: int) -> None: ...
    def clear_fallback_fonts(self) -> None: ...
    def authenticate_user_password(self, password: str) -> bool: ...
    def authenticate_owner_password(self, password: str) -> bool: ...
    def save(self, path: str) -> None: ...
    def save_bytes(self) -> bytes: ...
    def save_with_object_streams(self, path: str) -> None: ...
    def save_bytes_with_object_streams(self) -> bytes: ...
    def save_encrypted(
        self, path: str, user_password: str, owner_password: str, permissions: int, file_encryption_key: bytes
    ) -> None: ...
    def save_bytes_encrypted(
        self, user_password: str, owner_password: str, permissions: int, file_encryption_key: bytes
    ) -> bytes: ...
    def get_toc(self) -> list[tuple[int, str, int]]: ...
    def set_toc(self, entries: list[tuple[int, str, int]]) -> None: ...
    def page_count(self) -> int: ...
    def version(self) -> str: ...
    def get_metadata(self) -> dict[str, str]: ...
    def set_metadata(self, key: str, value: str) -> None: ...
    def delete_pages(self, page_numbers: list[int]) -> None: ...
    def get_page_rotation(self, page_number: int) -> int: ...
    def set_page_rotation(self, page_number: int, rotation: int) -> None: ...
    def get_page_box(self, page_number: int, key: str) -> tuple[float, float, float, float] | None: ...
    def set_page_box(self, page_number: int, key: str, x0: float, y0: float, x1: float, y1: float) -> None: ...
    def select(self, page_numbers: list[int]) -> None: ...
    def extract_text(self, page_numbers: list[int]) -> str: ...
    def extract_layout(
        self, page_number: int
    ) -> tuple[
        float,
        float,
        list[
            tuple[
                tuple[float, float, float, float],
                list[
                    tuple[
                        tuple[float, float, float, float],
                        list[tuple[tuple[float, float, float, float], str, float, tuple[float, float]]],
                        list[tuple[tuple[float, float, float, float], str]],
                    ]
                ],
            ]
        ],
    ]: ...
    def search_page(self, page_number: int, needle: str) -> list[tuple[float, float, float, float]]: ...
    def extract_images(
        self, page_number: int
    ) -> list[tuple[int, int, tuple[float, float, float, float], str, bytes]]: ...
    def render_page_pixmap(
        self, page_number: int, scale: float, background: tuple[int, int, int, int] | None
    ) -> Pixmap: ...
    def take_warnings(self) -> list[str]: ...
    def insert_image(
        self,
        page_number: int,
        rect: tuple[float, float, float, float],
        data: bytes,
        keep_proportion: bool,
        overlay: bool,
    ) -> None: ...
    def show_pdf_page(
        self,
        page_number: int,
        rect: tuple[float, float, float, float],
        other: _Document,
        src_page_number: int,
        keep_proportion: bool,
        overlay: bool,
    ) -> None: ...
    def replace_text_on_page(
        self, page_number: int, search: str, replacement: str, default_char: str | None
    ) -> int: ...
    def merge(self, other: _Document) -> None: ...
    def merge_pages(self, other: _Document, page_numbers: list[int], position: int | None) -> None: ...
    def new_page(self, position: int | None, width: float, height: float) -> None: ...
    def copy_page(self, page_number: int, position: int | None) -> None: ...
    def render_page_png(
        self, page_number: int, scale: float, background: tuple[int, int, int, int] | None
    ) -> bytes: ...
    def render_page_svg(self, page_number: int) -> str: ...
    def compress(self) -> None: ...
    def decompress(self) -> None: ...
    def prune_objects(self) -> None: ...
